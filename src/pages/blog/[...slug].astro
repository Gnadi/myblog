---
import {useStoryblokApi} from '@storyblok/astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE_URL } from "../../consts";
import {Image} from 'astro:assets';
import ThemeToggle from "../../components/ThemeToggle.astro";
import { getReadingTime } from '../../utils/readingTime';
import { getRelatedPosts } from '../../utils/relatedPosts';
import { getAllStories, contentVersion } from '../../utils/storyblok';
import RelatedPosts from '../../storyblok/RelatedPosts.astro';

export async function getStaticPaths() {
    const sbApi = useStoryblokApi();

    const stories = await getAllStories(sbApi, {
        version: contentVersion,
        starts_with: "blog/",
    });

    return stories.map((story) => {
        return {
            params: {slug: story.slug},
        };
    });
}

const sbApi = useStoryblokApi();
const {slug} = Astro.params;
const {data} = await sbApi.get(`cdn/stories/blog/${slug}`, {
    version: contentVersion,
});

const story = data.story;

const allStories = await getAllStories(sbApi, {
    version: contentVersion,
    starts_with: "blog/",
});

const readingTime = getReadingTime(story.content.content ?? '');

const relatedPosts = getRelatedPosts(
    story.full_slug,
    story.tag_list ?? [],
    allStories.map((s: any) => ({
        slug: s.full_slug,
        tags: s.tag_list ?? [],
        title: s.content.title,
        description: s.content.description ?? '',
        image: s.content.image?.filename ?? '',
        date: new Date(s.published_at).toLocaleDateString("de-AT", { dateStyle: "medium" }),
    }))
);

const heroImage = story.content.image?.filename;
---
<script>
    import hljs from 'highlight.js/lib/common';
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('pre code').forEach((block:HTMLElement) => {
            hljs.highlightElement(block);
        });
    });
</script>

<BaseLayout
  title={story.content.title}
  description={story.content.description || undefined}
  image={heroImage ? `${heroImage}/m/1200x630/filters:format(webp)` : undefined}
  url={new URL(`/blog/${slug}`, SITE_URL).href}
  type="article"
  publishedDate={story.content.pubDate}
>
    <div class="relative w-full invisible lg:visible">
        <div class="absolute right-5 top-5 lg:right-10 lg:top-10">
            <ThemeToggle />
        </div>
    </div>
    <div class="px-8 py-12 md:px-12 mx-auto lg:pb-24 max-w-7xl lg:px-32 lg:pt-32">
      <div class="lg:text-center">
        {heroImage && (
          <Image
                  class="lg:h-72 w-full  object-cover object-center rounded-xl"
                  src={`${heroImage}/m/1200x800/filters:format(webp)`}
                  alt={story.content.title}
                  width="1200"
                  height="800"
                  loading="eager"
                  fetchpriority='high'
          />
        )}
          <div class="flex  flex-col md:flex-row mt-4 justify-between">
              <p class="text-xs text-zinc-500 ">{story.content.pubDate?.toString().slice(0, 10)} - Written by: {story.content.author} · {readingTime} min Lesezeit</p>
              <div class="flex gap-3">
                  {
                      (story.tag_list ?? []).map((tag: string) => (
                          <a href={`/tags/${encodeURIComponent(tag)}`} class="inline-flex items-center uppercase text-xs font-medium text-black dark:text-white hover:text-zinc-500 dark:hover:text-zinc-300 transition-colors">
                              {tag}
                          </a>
                      ))
                  }
              </div>
          </div>
      </div>

        <div class="mt-12 max-w-2xl mx-auto">
            <div class="prose-styles">
                <StoryblokComponent blok={story.content}/>
            </div>
        </div>
        <RelatedPosts posts={relatedPosts} />
        <div class="justify-center pt-4 w-full hidden max-lg:flex">
                <ThemeToggle />
        </div>
    </div>
</BaseLayout>
