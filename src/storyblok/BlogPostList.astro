---
import { storyblokEditable } from '@storyblok/astro'
import EntriesOne from "../components/entries/EntriesOne.astro";
import { getReadingTime } from '../utils/readingTime';

const { blokdata, blok } = Astro.props;

const posts = blokdata.stories.map(story => {
    return {
        title: story.content.title,
        date: new Date(story.published_at).toLocaleDateString("de-AT", {dateStyle: "medium"}),
        description: story.content.description,
        image: story.content.image,
        tags: story.tag_list ?? [],
        slug: story.full_slug,
        readingTime: getReadingTime(story.content.content ?? story.content.description ?? ''),
    }
})
---
<ul class="grid grid-cols-1 mt-12 gap-3 gap-y-24 lg:grid-cols-2 sm:grid-cols-2" {...(blok ? storyblokEditable(blok) : {})}>
    {posts.map(((post, index) => (
            <EntriesOne
                    url={post.slug}
                    title={post.title}
                    description={post.description}
                    alt={post.title}
                    pubDate={post.date}
                    image={post.image?.filename}
                    tags={post.tags}
                    index={index}
                    readingTime={post.readingTime}
            />
    )))}
</ul>
